{
    "name": "@diia-inhouse/i18n",
    "version": "2.8.11",
    "description": "Internationalization package",
    "repository": "https://github.com/diia-open-source/be-pkg-i18n",
    "license": "SEE LICENSE IN LICENSE.md",
    "author": "Diia",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "find-circulars": "madge --circular ./",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "semantic-release": "semantic-release",
        "test": "vitest run",
        "test:watch": "vitest watch"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "eslintConfig": {
        "extends": "@diia-inhouse/eslint-config",
        "overrides": [
            {
                "files": [
                    "*.ts"
                ],
                "parserOptions": {
                    "project": [
                        "./tsconfig.json",
                        "./tests/tsconfig.json"
                    ]
                }
            }
        ]
    },
    "release": {
        "branches": [
            "main"
        ],
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "dependencies": {
        "@diia-inhouse/diia-logger": "3.19.9",
        "@diia-inhouse/diia-metrics": "6.5.16",
        "@types/i18n": "0.13.12",
        "glob": "11.1.0",
        "he": "1.2.0",
        "i18n": "0.15.3",
        "i18next": "25.8.13",
        "i18next-fs-backend": "2.6.1",
        "type-fest": "4.38.0"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.2",
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.14",
        "@diia-inhouse/types": "11.7.0",
        "@types/he": "1.2.3",
        "@types/node": "25.3.3",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.9",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=1.0.0"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
