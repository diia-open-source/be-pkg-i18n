{
    "name": "@diia-inhouse/i18n",
    "version": "3.1.16",
    "type": "module",
    "description": "Internationalization package",
    "repository": "https://github.com/diia-open-source/be-pkg-i18n",
    "license": "SEE LICENSE IN LICENSE.md",
    "author": "Diia",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsdown",
        "find-circulars": "madge --circular ./",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "semantic-release": "semantic-release",
        "test": "vitest run",
        "test:watch": "vitest watch"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "release": {
        "branches": [
            "main"
        ],
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "dependencies": {
        "@diia-inhouse/diia-logger": "4.3.24",
        "@diia-inhouse/diia-metrics": "7.1.33",
        "@types/i18n": "0.13.12",
        "glob": "13.0.6",
        "he": "1.2.0",
        "i18n": "0.15.3",
        "i18next": "25.8.13",
        "i18next-fs-backend": "2.6.5",
        "type-fest": "5.6.0"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.2",
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/eslint-config": "8.8.5",
        "@diia-inhouse/test": "8.2.13",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/types": "13.3.0",
        "@types/he": "1.2.3",
        "@types/node": "25.6.2",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "tsdown": "0.22.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.5",
        "vitest-mock-extended": "4.0.0"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=13.1.0"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
